    let currentIndex = 0;

    function init() {
      renderChapterList();
      loadChapter(0);
    }

    function renderChapterList() {
      const chapterList = document.getElementById('chapterList');
      const volumes = [
        { name: '第一卷：离乡', chapters: chapters.filter(c => c.volume === '第一卷：离乡') },
        { name: '第二卷', chapters: chapters.filter(c => c.volume === '第二卷') },
        { name: '第三部：而立之年', chapters: chapters.filter(c => c.volume === '第三部：而立之年') }
      ];
      
      volumes.forEach(volume => {
        const volumeTitle = document.createElement('div');
        volumeTitle.className = 'volume-title';
        volumeTitle.textContent = volume.name;
        chapterList.appendChild(volumeTitle);
        
        volume.chapters.forEach(chapter => {
          const li = document.createElement('li');
          li.className = 'chapter-item';
          li.dataset.index = chapter.globalIndex;
          li.textContent = chapter.title;
          li.onclick = () => loadChapter(chapter.globalIndex);
          chapterList.appendChild(li);
        });
      });
    }

    function loadChapter(index) {
      if (index < 0 || index >= chapters.length) return;
      
      currentIndex = index;
      const chapter = chapters[index];
      
      document.querySelectorAll('.chapter-item').forEach((item, i) => {
        item.classList.toggle('active', i === index);
      });
      
      document.getElementById('contentVolume').textContent = chapter.volume;
      document.getElementById('contentTitle').textContent = chapter.title;
      
      fetch('/chapters/' + chapter.id + '.md')
        .then(response => response.text())
        .then(text => {
          const html = markdownToHtml(text);
          document.getElementById('contentBody').innerHTML = html;
        })
        .catch(error => {
          document.getElementById('contentBody').innerHTML = '<p style="color: #999;">加载失败，请检查文件是否存在</p>';
        });
      
      updateNavButtons();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }

    function markdownToHtml(text) {
      let processed = text.replace(/^#[^\n]+\n\n/, '');
      processed = processed.replace(/^##\s+(.+)$/gm, '<h2>$1</h2>');
      processed = processed.replace(/^---+$/gm, '<hr>');
      processed = processed.replace(/^\*\((.+)\)$/gm, '<em>($1)</em>');
      
      const lines = processed.split(/\r?\n/);
      const htmlLines = lines.map(line => {
        const trimmed = line.trim();
        if (trimmed === '') return '';
        if (trimmed.startsWith('<h2>') || trimmed.startsWith('<hr>') || trimmed.startsWith('<em>')) {
          return trimmed;
        }
        return '<p>' + trimmed + '</p>';
      });
      
      return htmlLines.join('\n');
    }

    function prevChapter() {
      loadChapter(currentIndex - 1);
    }

    function nextChapter() {
      loadChapter(currentIndex + 1);
    }

    function updateNavButtons() {
      document.getElementById('prevBtn').disabled = currentIndex === 0;
      document.getElementById('nextBtn').disabled = currentIndex === chapters.length - 1;
    }

    document.addEventListener('DOMContentLoaded', init);
  </script>
</body>
</html>
