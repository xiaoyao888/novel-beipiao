---
import { chapters } from '../data/chapters';

const volumes = [
  { id: 'volume1', name: '第一卷：离乡', chapters: chapters.filter(c => c.volume === '第一卷：离乡') },
  { id: 'volume2', name: '第二卷', chapters: chapters.filter(c => c.volume === '第二卷') },
  { id: 'volume3', name: '第三部：而立之年', chapters: chapters.filter(c => c.volume === '第三部：而立之年') }
];
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>北漂 - 章节阅读</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'PingFang SC', 'Microsoft YaHei', serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
    }

    .container {
      display: flex;
      max-width: 1200px;
      margin: 0 auto;
      min-height: 100vh;
    }

    .sidebar {
      width: 300px;
      background: rgba(255, 255, 255, 0.95);
      padding: 30px;
      overflow-y: auto;
      box-shadow: 2px 0 20px rgba(0, 0, 0, 0.1);
    }

    .logo {
      font-size: 24px;
      font-weight: bold;
      color: #333;
      margin-bottom: 30px;
      padding-bottom: 20px;
      border-bottom: 1px solid #eee;
    }

    .volume-title {
      font-size: 14px;
      color: #999;
      margin: 20px 0 10px;
      padding-left: 10px;
      border-left: 3px solid #667eea;
    }

    .chapter-list {
      list-style: none;
    }

    .chapter-item {
      padding: 12px 15px;
      margin: 5px 0;
      border-radius: 8px;
      cursor: pointer;
      transition: all 0.3s ease;
      color: #555;
      font-size: 14px;
    }

    .chapter-item:hover {
      background: #f0f0ff;
      color: #667eea;
    }

    .chapter-item.active {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }

    .content-area {
      flex: 1;
      background: rgba(255, 255, 255, 0.98);
      padding: 50px 80px;
      overflow-y: auto;
    }

    .content-header {
      margin-bottom: 40px;
    }

    .content-volume {
      font-size: 14px;
      color: #667eea;
      margin-bottom: 10px;
    }

    .content-title {
      font-size: 32px;
      color: #333;
      margin-bottom: 20px;
    }

    .content-body {
      line-height: 2;
      color: #444;
      font-size: 16px;
    }

    .content-body p {
      margin-bottom: 20px;
      text-indent: 2em;
    }

    .content-body h2 {
      font-size: 22px;
      color: #333;
      margin: 30px 0 15px;
    }

    .content-body hr {
      border: none;
      height: 1px;
      background: linear-gradient(90deg, transparent, #ddd, transparent);
      margin: 40px 0;
    }

    .content-body em {
      color: #888;
      font-style: normal;
    }

    .nav-buttons {
      display: flex;
      justify-content: space-between;
      margin-top: 50px;
      padding-top: 30px;
      border-top: 1px solid #eee;
    }

    .nav-btn {
      padding: 12px 30px;
      border: none;
      border-radius: 30px;
      cursor: pointer;
      transition: all 0.3s ease;
      font-size: 14px;
    }

    .nav-btn:hover:not(:disabled) {
      transform: translateY(-2px);
      box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
    }

    .nav-btn:disabled {
      background: #eee;
      color: #ccc;
      cursor: not-allowed;
    }

    .nav-btn-primary {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      color: white;
    }

    .nav-btn-secondary {
      background: #f5f5f5;
      color: #666;
    }

    .footer {
      text-align: center;
      padding: 20px;
      color: #999;
      font-size: 12px;
    }

    @media (max-width: 768px) {
      .container {
        flex-direction: column;
      }

      .sidebar {
        width: 100%;
        padding: 20px;
        max-height: 300px;
      }

      .content-area {
        padding: 20px;
      }

      .content-title {
        font-size: 24px;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="sidebar">
      <div class="logo">北漂</div>
      <ul class="chapter-list" id="chapterList"></ul>
    </div>
    
    <div class="content-area">
      <div class="content-header">
        <div class="content-volume" id="contentVolume"></div>
        <h1 class="content-title" id="contentTitle"></h1>
      </div>
      <div class="content-body" id="contentBody"></div>
      <div class="nav-buttons">
        <button class="nav-btn nav-btn-secondary" id="prevBtn" onclick="prevChapter()" disabled>上一章</button>
        <button class="nav-btn nav-btn-primary" id="nextBtn" onclick="nextChapter()">下一章</button>
      </div>
      <div class="footer">© 2024 北漂 - 一个关于奋斗与成长的故事</div>
    </div>
  </div>

